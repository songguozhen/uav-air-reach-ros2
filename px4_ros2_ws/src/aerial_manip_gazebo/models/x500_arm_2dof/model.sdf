<?xml version="1.0" encoding="UTF-8"?>
<sdf version="1.9">
  <model name="x500_arm_2dof">
    <include merge="true">
      <uri>x500</uri>
    </include>

    <include merge="true">
      <uri>model://mono_cam</uri>
      <pose>0.12 0 0.242 0 0 0</pose>
    </include>

    <joint name="CameraJoint" type="fixed">
      <parent>base_link</parent>
      <child>camera_link</child>
      <pose relative_to="base_link">0.12 0 0.242 0 0 0</pose>
    </joint>

    <link name="arm_link_1">
      <pose relative_to="base_link">0.20 0 -0.08 0 0 0</pose>
      <inertial>
        <mass>0.08</mass>
        <inertia>
          <ixx>0.0000163</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0002748</iyy>
          <iyz>0</iyz>
          <izz>0.0002748</izz>
        </inertia>
      </inertial>
      <collision name="arm_link_1_collision">
        <geometry>
          <box>
            <size>0.20 0.035 0.035</size>
          </box>
        </geometry>
        <surface>
          <contact>
            <ode>
              <min_depth>0.001</min_depth>
              <max_vel>0.1</max_vel>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>0.6</mu>
              <mu2>0.6</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="arm_link_1_visual">
        <geometry>
          <box>
            <size>0.20 0.035 0.035</size>
          </box>
        </geometry>
        <material>
          <ambient>0.05 0.18 0.42 1</ambient>
          <diffuse>0.05 0.18 0.42 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
    </link>

    <link name="arm_link_2">
      <pose relative_to="base_link">0.38 0 -0.08 0 0 0</pose>
      <inertial>
        <mass>0.06</mass>
        <inertia>
          <ixx>0.0000090</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0001325</iyy>
          <iyz>0</iyz>
          <izz>0.0001325</izz>
        </inertia>
      </inertial>
      <collision name="arm_link_2_collision">
        <geometry>
          <box>
            <size>0.16 0.03 0.03</size>
          </box>
        </geometry>
        <surface>
          <contact>
            <ode>
              <min_depth>0.001</min_depth>
              <max_vel>0.1</max_vel>
            </ode>
          </contact>
          <friction>
            <ode>
              <mu>0.6</mu>
              <mu2>0.6</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="arm_link_2_visual">
        <geometry>
          <box>
            <size>0.16 0.03 0.03</size>
          </box>
        </geometry>
        <material>
          <ambient>0.12 0.36 0.22 1</ambient>
          <diffuse>0.12 0.36 0.22 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
    </link>

    <joint name="arm_shoulder_pitch_joint" type="revolute">
      <parent>base_link</parent>
      <child>arm_link_1</child>
      <pose relative_to="base_link">0.10 0 -0.08 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-0.7</lower>
          <upper>0.7</upper>
          <effort>1.0</effort>
          <velocity>1.5</velocity>
        </limit>
        <dynamics>
          <damping>0.20</damping>
          <friction>0.01</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="arm_elbow_pitch_joint" type="revolute">
      <parent>arm_link_1</parent>
      <child>arm_link_2</child>
      <pose relative_to="base_link">0.30 0 -0.08 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1.2</lower>
          <upper>1.2</upper>
          <effort>0.8</effort>
          <velocity>1.5</velocity>
        </limit>
        <dynamics>
          <damping>0.18</damping>
          <friction>0.01</friction>
        </dynamics>
      </axis>
    </joint>

    <ros2_control name="x500_arm_2dof_ros2_control" type="system">
      <hardware>
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </hardware>

      <joint name="arm_shoulder_pitch_joint">
        <command_interface name="position">
          <param name="min">-0.7</param>
          <param name="max">0.7</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="arm_elbow_pitch_joint">
        <command_interface name="position">
          <param name="min">-1.2</param>
          <param name="max">1.2</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
    </ros2_control>

    <plugin
      filename="gz_ros2_control-system"
      name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find aerial_manip_control)/config/arm_controllers.yaml</parameters>
    </plugin>
  </model>
</sdf>
