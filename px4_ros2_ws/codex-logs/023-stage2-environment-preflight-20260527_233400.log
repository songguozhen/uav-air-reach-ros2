#!/usr/bin/env bash
set -uo pipefail

WORKSPACE_ROOT="${WORKSPACE_ROOT:-/home/clcwork/UAV_capture/px4_ros2_ws}"
PX4_DIR="${PX4_DIR:-/home/clcwork/UAV_capture/px4_ws/PX4-Autopilot}"
