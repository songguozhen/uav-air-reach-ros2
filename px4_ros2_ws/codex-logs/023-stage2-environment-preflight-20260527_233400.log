+  add_recheck "test -d /opt/ros/jazzy"
+  live_ready=0
+fi
+
+if command -v gz >/dev/null 2>&1; then
+  gz_version="$(gz sim --versions 2>/dev/null | head -n 1)"
+  report PASS "gazebo_sim" "path=$(command -v gz) version=${gz_version:-unknown}"
