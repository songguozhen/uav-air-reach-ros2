+        ax.axhline(limit, linestyle="--", color="tab:red", label=f"limit {limit:.2f} m")
+    ax.set_title(title(context, "Endpoint Error"))
+    ax.set_xlabel("Time since episode start (s)")
+    ax.set_ylabel("Endpoint error (m)")
