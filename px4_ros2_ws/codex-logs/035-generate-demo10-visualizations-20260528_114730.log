+    times: list[float] = []
+    errors: list[float] = []
+    for row in context["observations"]:
+        t = rel_time(row, context["time_zero"])
+        point = vector(row, "platform", "position_ned")
+        if t is None or point is None:
+            continue
+        idx = bisect.bisect_right(target_times, t) - 1
+        if idx < 0:
