@@ -1,13 +1,65 @@
 #!/usr/bin/env bash
 set -euo pipefail
 
-tmux kill-session -t px4_offboard_hover 2>/dev/null || true
-tmux kill-session -t px4_demo02_waypoint_flight 2>/dev/null || true
