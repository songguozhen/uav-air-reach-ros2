+
+wait_until_clear "gz sim .*${PX4_DIR}/Tools/simulation/gz/worlds/default\\.sdf" \
+  "Gazebo default.sdf with PX4 world path"
+wait_until_clear "gz sim --verbose=1 -r -s .*default\\.sdf" \
