+        "## Demo 10 Evidence",
+        "",
+        f"- dry_run_status: `{dry_run['status']}`",
+        f"- dry_run_path: `{dry_run.get('path', 'n/a')}`",
+        f"- dry_run_result: `{dry_run.get('result', 'n/a')}`",
+        f"- live_status: `{live['status']}`",
+        f"- live_path: `{live.get('path', 'n/a')}`",
+        f"- live_result: `{live.get('result_line', 'n/a')}`",
+        "",
