+        lines.append(f"- {entry['name']}: `{state}` `{entry['path']}`")
+
+    lines.extend(
+        [
+            "",
+            "## Task 012-022 Evidence",
+            "",
+            f"- task_evidence_status: `{tasks['status']}`",
+            f"- mismatches: `{len(tasks['mismatches'])}`",
+        ]
+    )
+    for mismatch in tasks["mismatches"]:
