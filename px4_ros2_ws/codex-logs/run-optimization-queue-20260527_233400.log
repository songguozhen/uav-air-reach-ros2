+record_readiness() {
+  local status="$1"
+  local reason="$2"
+  local detail="$3"
+  local line
+
+  line="STACK_READY=${status} reason=${reason} detail=${detail}"
+  printf '%s\n' "$line"
+  if [ -n "$READINESS_RESULT_FILE" ]; then
+    printf '%s\n' "$line" >"$READINESS_RESULT_FILE"
+  fi
+}
 
+latest_preflight_failure() {
