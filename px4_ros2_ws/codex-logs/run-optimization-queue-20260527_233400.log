+terminate_matching "px4_sitl_default/bin/px4" "PX4 SITL"
+terminate_matching "MicroXRCEAgent .*udp4 .*8888" "Micro XRCE-DDS Agent"
+
+wait_until_clear "gz sim .*${PX4_DIR}/Tools/simulation/gz/worlds/default\\.sdf" \
