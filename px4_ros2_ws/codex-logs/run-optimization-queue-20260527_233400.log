+for _ in $(seq 1 "$STACK_READY_TIMEOUT"); do
+  if grep -q "Ready for takeoff" "$PX4_STACK_LOG" 2>/dev/null; then
+    record_readiness YES ready_for_takeoff "PX4 reached Ready for takeoff"
