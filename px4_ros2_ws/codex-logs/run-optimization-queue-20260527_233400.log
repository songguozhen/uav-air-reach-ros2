+  local pattern="$1"
+  local label="$2"
+
+  for _ in $(seq 1 10); do
+    if ! pgrep -f "$pattern" >/dev/null 2>&1; then
+      return 0
+    fi
+    sleep 1
+  done
+
+  printf '[stop_stack] warning: process still matched after cleanup: %s\n' "$label" >&2
+  pgrep -af "$pattern" >&2 || true
+}
