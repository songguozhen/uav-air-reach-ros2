+                "log_files": [relative(path) for path in log_files],
+                "log_count": len(log_files),
+                "mismatch": mismatch,
+            }
+        )
+
+    return {
+        "status": "PASS" if not mismatches else "FAIL",
+        "task_range": f"{first_task:03d}-{last_task:03d}",
+        "tasks": task_entries,
+        "mismatches": mismatches,
+    }
