+        "flight_error_limit_m": metrics.get("flight_error", {}).get("limit_m"),
+        "target_visible_ratio": metrics.get("target_visibility", {}).get("visible_ratio"),
+        "target_min_visible_ratio": metrics.get("target_visibility", {}).get(
