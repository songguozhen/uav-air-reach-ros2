+  add_recheck "source /opt/ros/jazzy/setup.bash && echo \$ROS_DISTRO"
+  live_ready=0
+else
+  report FAIL "ros2_distro" "missing_prefix=/opt/ros/jazzy expected=ROS_DISTRO=jazzy recheck=\"test -d /opt/ros/jazzy\""
+  add_recheck "test -d /opt/ros/jazzy"
