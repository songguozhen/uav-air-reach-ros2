    39	def ned_to_enu_xyz(point_ned: Sequence[float]) -> Vector3:
    40	    """Convert PX4 local NED xyz to ROS ENU xyz."""
    41	    if len(point_ned) != 3:
    42	        raise ValueError("point_ned must contain exactly 3 values")
    43	    x_ned, y_ned, z_ned = point_ned
    44	    return float(y_ned), float(x_ned), float(-z_ned)
    45	
    46	
    47	def enu_to_ned_xyz(point_enu: Sequence[float]) -> Vector3:
    48	    """Convert ROS ENU xyz back to PX4 local NED xyz."""
    49	    if len(point_enu) != 3:
    50	        raise ValueError("point_enu must contain exactly 3 values")
    51	    x_enu, y_enu, z_enu = point_enu
    52	    return float(y_enu), float(x_enu), float(-z_enu)

