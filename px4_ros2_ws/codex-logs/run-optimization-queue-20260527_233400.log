        self.declare_parameter("min_standoff_distance_m", 0.25)
        self.declare_parameter("max_standoff_distance_m", 3.0)
        self.declare_parameter("max_horizontal_range", 8.0)
        self.declare_parameter("min_altitude", 0.4)
