+fi
+
+if [ "$warn_count" -gt 0 ]; then
+  printf 'RESULT=WARN reason=vision_smoke_completed_with_warnings\n'
+else
+  printf 'RESULT=PASS reason=vision_smoke_verified\n'
+fi

