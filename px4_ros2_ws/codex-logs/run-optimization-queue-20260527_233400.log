 import time
 from typing import List, Optional, Sequence, Tuple
 
+from aerial_manip_control.stage2_schema import (
+    CANONICAL_ARM_JOINT_NAMES,
+    CANONICAL_FRAMES,
+    DEFAULT_ARM_MAX_POSITIONS,
