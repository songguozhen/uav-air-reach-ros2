+wait_for_ros_topic() {
+  local topic="$1"
+  local timeout_sec="$2"
+  local deadline=$((SECONDS + timeout_sec))
+
+  while [ "$SECONDS" -lt "$deadline" ]; do
+    if ros2 topic list 2>/dev/null | grep -Fxq "$topic"; then
+      return 0
+    fi
+    sleep 1
+  done
+  return 1
+}
