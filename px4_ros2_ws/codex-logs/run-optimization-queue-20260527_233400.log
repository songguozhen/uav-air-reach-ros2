    add_recheck "test -x $python_bin"
    if [ "$effect" = "dry-run" ]; then
      dry_run_ready=0
    fi
    return
  fi

  version="$("$python_bin" -c 'import importlib.metadata; print(importlib.metadata.version("lerobot"))' 2>/dev/null)"
  if [ -n "$version" ]; then
