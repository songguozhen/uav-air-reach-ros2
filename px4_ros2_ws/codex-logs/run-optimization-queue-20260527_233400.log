+    printf '  %s\n' "$cmd"
+  done
+fi
+
+printf '\n'
+printf 'SUMMARY pass=%d warn=%d fail=%d\n' "$pass_count" "$warn_count" "$fail_count"
+
+if [ "$fail_count" -gt 0 ]; then
