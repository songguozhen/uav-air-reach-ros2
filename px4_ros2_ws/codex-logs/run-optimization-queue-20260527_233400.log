            + (left[1] - right[1]) ** 2
            + (left[2] - right[2]) ** 2
        )


def main(args=None) -> None:
    rclpy.init(args=args)
    node = ApproachCoordinator()
    executor = MultiThreadedExecutor()
    executor.add_node(node)
    try:
        executor.spin()
    except (ExternalShutdownException, KeyboardInterrupt):
        pass
    finally:
        executor.shutdown()
        node.destroy_node()
        if rclpy.ok():
            rclpy.shutdown()


if __name__ == "__main__":
    main()

