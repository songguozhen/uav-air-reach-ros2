+- DEMO10_MODE=live-smoke RESET_STACK=1 bash scripts/run_regression_demo_10.sh
+- RESET_STACK=1 timeout 95s scripts/start_stack.sh || true
+- scripts/stop_stack.sh
+- pgrep -af 'gz sim|px4|MicroXRCEAgent' || true
+- pgrep -af 'gz sim .*default\.sdf|px4_sitl_default/bin/px4|MicroXRCEAgent .*udp4' || true
+- python3 -m compileall src scripts
