+  local pattern="$1"
+  local label="$2"
+
+  if ! pgrep -f "$pattern" >/dev/null 2>&1; then
+    return 0
+  fi
+
+  printf '[stop_stack] stopping %s\n' "$label"
+  pkill -TERM -f "$pattern" 2>/dev/null || true
+  sleep 2
+
+  if pgrep -f "$pattern" >/dev/null 2>&1; then
+    printf '[stop_stack] force stopping %s\n' "$label"
+    pkill -KILL -f "$pattern" 2>/dev/null || true
+  fi
+}
+
