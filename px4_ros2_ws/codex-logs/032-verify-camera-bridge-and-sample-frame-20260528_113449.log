    node = FrameGrabber(topic, output_path)
    try:
        while rclpy.ok() and not node.saved:
            rclpy.spin_once(node, timeout_sec=0.25)
    finally:
        node.destroy_node()
        rclpy.shutdown()
    return 0 if os.path.exists(output_path) else 1


sys.exit(main())
