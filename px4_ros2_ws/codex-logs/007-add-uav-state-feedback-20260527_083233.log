   134	    def _validate_target(
   135	        self, target: Position, check_jump: bool
   136	    ) -> Optional[str]:
   137	        x, y, z = target
   138	        if not all(math.isfinite(value) for value in target):
   139	            return "target contains non-finite values"
   140	
   141	        altitude = -z
   142	        if altitude <= 0.0:
   143	            return "positive altitude commands are not accepted; publish NED z=-altitude"
   144	        if altitude > self.max_altitude:
   145	            return (
   146	                f"altitude {altitude:.2f} m exceeds max_altitude "
   147	                f"{self.max_altitude:.2f} m"
   148	            )
   149	        if altitude < self.min_altitude:
   150	            return (
   151	                f"altitude {altitude:.2f} m is below min_altitude "
   152	                f"{self.min_altitude:.2f} m"
   153	            )
   154	
   155	        horizontal_range = math.hypot(x, y)
   156	        if horizontal_range > self.max_horizontal_range:
   157	            return (
   158	                f"horizontal range {horizontal_range:.2f} m exceeds "
   159	                f"max_horizontal_range {self.max_horizontal_range:.2f} m"
   160	            )
   161	
   162	        if check_jump:
   163	            jump = self._distance(target, self.safe_target)
   164	            if jump > self.target_jump_limit:
   165	                return (
   166	                    f"target jump {jump:.2f} m exceeds target_jump_limit "
   167	                    f"{self.target_jump_limit:.2f} m"
   168	                )
   169	
   170	        return None
   171	
   172	    def _target_timed_out(self, now: float) -> bool:
   173	        if self.target_timeout <= 0.0:
   174	            return False
   175	
   176	        return now - self.last_safe_target_time > self.target_timeout
   177	
   178	    def _warn_if_target_timed_out(self, now: float) -> None:
   179	        if not self._target_timed_out(now):
   180	            return
   181	        if now - self.last_timeout_warning_time < self.target_timeout:
   182	            return
   183	
   184	        self.get_logger().warn("Target timeout; holding last safe target")
   185	        self.last_timeout_warning_time = now
   186	
   187	    def _update_reached_target(self) -> None:
   188	        if self.current_position is None:
   189	            self.reach_start_time = None
   190	            self.reached_target = False
   191	            return
   192	
   193	        dx = self.current_position[0] - self.safe_target[0]
   194	        dy = self.current_position[1] - self.safe_target[1]
   195	        dz = self.current_position[2] - self.safe_target[2]
   196	        within_tolerance = (
   197	            math.hypot(dx, dy) <= self.reach_xy_tolerance
   198	            and abs(dz) <= self.reach_z_tolerance
   199	        )
   200	        if not within_tolerance:
   201	            self.reach_start_time = None
   202	            self.reached_target = False
   203	            return
   204	
   205	        now = time.monotonic()
   206	        if self.reach_start_time is None:
   207	            self.reach_start_time = now
   208	        self.reached_target = now - self.reach_start_time >= self.reach_hold_time
