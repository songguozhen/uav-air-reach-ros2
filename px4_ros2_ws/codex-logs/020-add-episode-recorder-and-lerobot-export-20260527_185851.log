        self.declare_parameter("max_uav_target_step", 0.5)
        self.declare_parameter("coarse_xy_tolerance", 0.25)
        self.declare_parameter("coarse_z_tolerance", 0.20)
        self.declare_parameter("arm_reach_tolerance", 0.18)
