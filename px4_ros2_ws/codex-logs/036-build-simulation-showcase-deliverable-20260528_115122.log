+    lines.extend(f"- {risk}" for risk in audit["risks"])
+    lines.extend(["", "## Next Actions", ""])
+    lines.extend(f"- {action}" for action in audit["next_actions"])
+    lines.append("")
+    return "\n".join(lines)
+
