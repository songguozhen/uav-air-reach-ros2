+    metric_rows = "\n".join(
+        f"<tr><th>{escape(key)}</th><td>{escape(format_value(value))}</td></tr>"
+        for key, value in metrics.items()
+    )
+    visual_cards = []
+    for item in visuals["files"]:
+        if item["exists"]:
+            visual_cards.append(
+                f"""<div class="card">
