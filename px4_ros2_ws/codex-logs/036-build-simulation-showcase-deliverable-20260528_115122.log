+        "final_endpoint_error_m": nested(metrics, "final_endpoint_error", "error_m"),
+        "final_endpoint_limit_m": nested(metrics, "final_endpoint_error", "limit_m"),
+        "timed_out": nested(metrics, "task_timeout", "timed_out"),
+    }
