+    footer {{ max-width: 1180px; margin: 0 auto; padding: 0 18px 24px; color: var(--muted); }}
+    @media (max-width: 900px) {{ .grid, .grid.two {{ grid-template-columns: 1fr; }} }}
+  </style>
+</head>
+<body>
+  <header>
+    <h1>PX4 ROS2 UAV Capture Simulation Showcase</h1>
+    <div class="hero-line">
