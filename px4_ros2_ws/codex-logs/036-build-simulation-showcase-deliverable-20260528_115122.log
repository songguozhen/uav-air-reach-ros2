+  <div class="artifact-links">
+    <a href="{href(str(visuals['path']) + '/summary.json')}">summary.json</a>
+    <a href="{href(str(live['path']) + '/metrics.json')}">metrics.json</a>
+    <a href="{href(str(live['path']) + '/result.txt')}">result.txt</a>
+  </div>
+</section>"""
