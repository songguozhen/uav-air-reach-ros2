diff --git a/UAV_capture/px4_ros2_ws/src/px4_offboard_hover/px4_offboard_hover/uav_control_bridge.py b/UAV_capture/px4_ros2_ws/src/px4_offboard_hover/px4_offboard_hover/uav_control_bridge.py
