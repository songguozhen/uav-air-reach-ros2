diff --git a/UAV_capture/px4_ros2_ws/src/aerial_manip_gazebo/launch/front_camera_bridge.launch.py b/UAV_capture/px4_ros2_ws/src/aerial_manip_gazebo/launch/front_camera_bridge.launch.py
