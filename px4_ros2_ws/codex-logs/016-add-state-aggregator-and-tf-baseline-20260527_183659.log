index 0000000000000000000000000000000000000000..1f76eeed600dfcaa43037130019de50b89084a0c
--- /dev/null
+++ b/UAV_capture/px4_ros2_ws/src/aerial_manip_msgs/msg/SafetyStatus.msg
@@ -0,0 +1,10 @@
