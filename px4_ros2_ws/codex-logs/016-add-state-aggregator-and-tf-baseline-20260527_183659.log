   <exec_depend>rclpy</exec_depend>
   <exec_depend>std_msgs</exec_depend>
+  <exec_depend>tf2_ros</exec_depend>
 
   <test_depend>ament_lint_auto</test_depend>
   <test_depend>ament_lint_common</test_depend>
diff --git a/UAV_capture/px4_ros2_ws/src/aerial_manip_control/setup.py b/UAV_capture/px4_ros2_ws/src/aerial_manip_control/setup.py
index 6e52e4cde67e4f78e609534d37174c9aad582112..5deb86d049762da0ba0e28b17b40aaf08575a4fd
--- a/UAV_capture/px4_ros2_ws/src/aerial_manip_control/setup.py
+++ b/UAV_capture/px4_ros2_ws/src/aerial_manip_control/setup.py
@@ -19,6 +19,7 @@
     entry_points={
         "console_scripts": [
             "arm_control_bridge = aerial_manip_control.arm_control_bridge:main",
