+#!/usr/bin/env bash
+set -euo pipefail
+
+WORKSPACE_ROOT="${WORKSPACE_ROOT:-/home/clcwork/UAV_capture/px4_ros2_ws}"
+PX4_GZ_MODELS="${PX4_GZ_MODELS:-/home/clcwork/UAV_capture/px4_ws/PX4-Autopilot/Tools/simulation/gz/models}"
