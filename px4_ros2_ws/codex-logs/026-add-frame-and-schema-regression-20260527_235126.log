+CONTROL_SRC = WORKSPACE_ROOT / "src" / "aerial_manip_control"
+sys.path.insert(0, str(CONTROL_SRC))
+
+from aerial_manip_control.stage2_schema import (  # noqa: E402
+    CANONICAL_ARM_DOF,
