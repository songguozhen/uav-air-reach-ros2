#!/usr/bin/env bash
set -euo pipefail

WS_DIR="${WS_DIR:-/home/clcwork/UAV_capture/px4_ros2_ws}"
ALTITUDE="${ALTITUDE:-2.0}"
VIS_DURATION="${VIS_DURATION:-30.0}"
HOVER_DURATION="${HOVER_DURATION:-35.0}"
STAMP="$(date +%Y%m%d_%H%M%S)"
LOG_DIR="$WS_DIR/logs/demo01_hover/$STAMP"
VIS_DIR="$WS_DIR/visualizations/demo01_hover/$STAMP"
export RESET_STACK="${RESET_STACK:-1}"

mkdir -p "$LOG_DIR" "$VIS_DIR"
"$WS_DIR/scripts/start_stack.sh"

tmux kill-session -t px4_trajectory_recorder 2>/dev/null || true
tmux new-session -d -s px4_trajectory_recorder \
  "VIS_DIR=\"$VIS_DIR\" VIS_DURATION=\"$VIS_DURATION\" VIS_TITLE=\"Demo 01 Hover\" VIS_DEMO_ID=\"demo01\" AVG_ERROR_PASS=\"0.8\" HEIGHT_ERROR_PASS=\"0.35\" MAX_SPEED_PASS=\"3.0\" \"$WS_DIR/scripts/run_trajectory_recorder.sh\" 2>&1 | tee \"$LOG_DIR/trajectory_recorder.log\""

tmux kill-session -t px4_offboard_hover 2>/dev/null || true
tmux new-session -d -s px4_offboard_hover \
  "cd \"$WS_DIR\" && set +u && source /opt/ros/jazzy/setup.bash && source install/setup.bash && set -u && ros2 run px4_offboard_hover hover --ros-args -p altitude:=$ALTITUDE -p hover_duration:=$HOVER_DURATION -p land_on_exit:=true 2>&1 | tee \"$LOG_DIR/demo01.log\""

echo "demo01 session=px4_offboard_hover"
echo "visualizer session=px4_trajectory_recorder"
echo "visual outputs will be written after ${VIS_DURATION}s"
echo "logs=$LOG_DIR"
echo "visuals=$VIS_DIR"
while tmux has-session -t px4_trajectory_recorder 2>/dev/null; do
